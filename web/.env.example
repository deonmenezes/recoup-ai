# ── Recoup AI CRM (web) — all optional ──────────────────────────────────────
# The CRM runs fully as a self-contained demo with NO env vars (the call console
# plays a high-fidelity scripted call and the Compliance Lab uses seeded Cekura
# results). Provide these only to wire the REAL voice-agent workflow.

# Twilio — when all three are set, POST /api/calls and /api/test-call place real
# outbound calls. TWILIO_FROM_NUMBER must be a voice-capable Twilio number you own.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Pipecat Cloud — the deployed bot the Twilio Stream connects to: <agent>.<org>
PIPECAT_AGENT_HOST=wss://api.pipecat.daily.co/ws/twilio
PIPECAT_SERVICE_HOST=flower-bot.deon

# "Call me" demo (/api/test-call) — optional allowlist of E.164 numbers. When set,
# ONLY these numbers can be dialed (lock to your own number after the demo to
# remove toll-fraud risk). Unset = US/Canada (+1) only, with per-IP rate limiting.
TEST_CALL_ALLOWLIST=

# Cekura — when set, /api/cekura reports "live" mode.
CEKURA_API_KEY=
