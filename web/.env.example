# ── Recoup AI CRM (web) — all optional ──────────────────────────────────────
# The CRM runs fully as a self-contained demo with NO env vars (the call console
# plays a high-fidelity scripted call and the Compliance Lab uses seeded Cekura
# results). Provide these only to wire the REAL voice-agent workflow.

# Twilio — when all three are set, POST /api/calls places a real outbound call.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Pipecat Cloud — the deployed bot the Twilio Stream connects to.
PIPECAT_AGENT_HOST=wss://api.pipecat.daily.co/ws/twilio
PIPECAT_SERVICE_HOST=recoup-bot.YOUR_ORG_NAME

# Cekura — when set, /api/cekura reports "live" mode.
CEKURA_API_KEY=
